# Root reference of all env vars. Copy the relevant ones into:
#   apps/web/.env.local        (NEXT_PUBLIC_* + anon key)
#   services/worker/.env       (service-role key + API keys)

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- CVR Elasticsearch (free creds via cvrselvbetjening@erst.dk) ---
CVR_ES_USER=
CVR_ES_PASSWORD=

# --- Enrichment / AI ---
PAGESPEED_API_KEY=
ANTHROPIC_API_KEY=

# --- Compliance (worker only) ---
# Path to the licensed Robinson opt-out register on the worker host. Licensed
# data — provision out-of-band, never commit it.
ROBINSON_LIST_PATH=
