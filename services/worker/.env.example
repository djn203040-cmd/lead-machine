SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CVR_ES_USER=
CVR_ES_PASSWORD=
# Optional override for the production-unit (P-enhed) index; defaults to the
# produktionsenhed distribution endpoint. Same creds as the company index —
# used to recover a storefront's trading name + its own site (e.g. Noribar).
CVR_ES_PENHED_URL=
PAGESPEED_API_KEY=
ANTHROPIC_API_KEY=
# Website discovery: Brave Web Search API key (optional — the free email/name
# tiers work without it). https://brave.com/search/api/
BRAVE_API_KEY=
# Optional override; defaults to claude-haiku-4-5 (cheap website quality grading).
WEBSITE_GRADER_MODEL=
# Path to the licensed Robinson opt-out register on the host (never commit it).
ROBINSON_LIST_PATH=
